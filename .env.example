# 环境变量配置示例
# 复制此文件为 .env 并填入您的 API Key

# ===========================================
# LLM 配置
# ===========================================
# Ollama 本地模型（默认使用，无需配置）
# 如需使用 OpenAI API：
# OPENAI_API_KEY=your-openai-api-key

# ===========================================
# 语音识别配置 (Whisper)
# ===========================================
# 本地模式（免费，需要安装 openai-whisper）
# 安装命令: pip install openai-whisper

# API 模式（更快更准，需要 OpenAI API Key）
# OPENAI_API_KEY=your-openai-api-key

# ===========================================
# 图像生成配置
# ===========================================

# SiliconFlow（推荐，国内访问快）
# 注册地址: https://cloud.siliconflow.cn
# 注册后获取 API Key
SILICONFLOW_API_KEY=

# Replicate（国外服务）
# REPLICATE_API_KEY=your-replicate-api-key

# Stability AI
# STABILITY_API_KEY=your-stability-api-key

# ===========================================
# 数字人视频生成配置
# ===========================================

# D-ID（推荐）
# 注册地址: https://www.d-id.com
# 免费试用: 5分钟视频额度
# 价格: 按量付费
D_ID_API_KEY=

# HeyGen
# 注册地址: https://www.heygen.com
# 免费试用: 1个积分
# 价格: $29/月起
HEYGEN_API_KEY=

# ===========================================
# 系统配置
# ===========================================
CONFIG_PATH=config/settings.yaml